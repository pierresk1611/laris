// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Shop {
  id        String   @id @default(cuid())
  url       String
  name      String   @default("Môj E-shop")
  ck        String
  cs        String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id           String   @id @default(cuid())
  key          String   @unique // e.g., JSO 15
  sku          String?  @unique // WooCommerce SKU
  name         String
  displayName  String?  // Mirka's custom name (alias replacement)
  mappedPaths  Int      @default(0)
  mappingData  Json?    // Stores the PSD layer to field mappings
  status       String   @default("PENDING_MAPPING")
  isVerified   Boolean  @default(false)
  imageUrl     String?
  alias        String?  // Deprecated: Display Name / User customized alias
  variants     Json?    @default("[]") // Deprecated: Array of { type, path, extension, imageUrl? }
  files        TemplateFile[]
  webProducts  WebProduct[] // Added for Smart Match
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TemplateFile {
  id          String   @id @default(cuid())
  templateId  String
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  type        String   @default("MAIN") // MAIN, INVITE, etc.
  path        String   // Dropbox path - REQUIRED
  extension   String?
  imageUrl    String?
  layers      Json?    @default("[]") // Extracted layers
  mapping     Json?    @default("{}") // Layer mapping
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([templateId, type])
}

model VerifiedTemplate {
  id            String   @id @default(cuid())
  internal_id   String?
  title         String
  template_code String   @unique
  category      String?
  image_url     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Job {
  id        String   @id @default(cuid())
  type      String   // e.g., LOAD_LAYERS, RENDER_PSD
  payload   Json?
  status    String   @default("PENDING") // PENDING, SUCCESS, ERROR
  result    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentStatus {
  id          String   @id @default(cuid())
  lastSeen    DateTime @default(now())
  status      String   @default("ONLINE")
  version     String?
  os          String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiPattern {
  id        String   @id @default(cuid())
  input     String
  output    Json
  createdAt DateTime @default(now())
}

model Setting {
  id        String   @id // Key name (e.g. "GROQ_API_KEY")
  value     String   // Encrypted value if isSecret is true
  category  String   @default("GENERAL") // GENERAL, AI, STORAGE, AGENT
  isSecret  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LocalOrderState {
  id          String   @id @default(cuid())
  orderId     String   // Woo Order ID (string to support various inputs)
  shopId      String
  status      String   @default("PROCESSING") // PROCESSING, READY_FOR_PRINT, PRINTED
  note        String?
  sheetFormat String?  @default("SRA3") // SRA3, A4, A3, METAL_225_300...
  isVerified  Boolean  @default(false)
  orderData   Json?    // Stores the full ProcessedItem[] or specific fields if verified
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orderId, shopId])
}

model FileInbox {
  id          String   @id @default(cuid())
  name        String
  path        String   @unique // Dropbox path
  extension   String
  status       String   @default("UNCLASSIFIED") // UNCLASSIFIED, PROCESSED, IGNORED
  prediction   Json?    // Stores AI prediction data { type: "TEMPLATE", confidence: 0.9, reasoning: "..." }
  thumbnailData String?  @db.Text // Base64 cached thumbnail
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AiClassificationExample {
  id        String   @id @default(cuid())
  filename  String
  category  String   // TEMPLATE, DOCUMENT, IGNORE
  reasoning String?
  createdAt DateTime @default(now())
}

model WebProduct {
  id              String    @id @default(cuid())
  shopId          String?   // WooCommerce Shop ID
  shopName        String?   // WooCommerce Shop Name
  title           String
  permalink       String?
  sku             String?
  imageUrl        String?   @db.Text
  templateId      String?
  template        Template? @relation(fields: [templateId], references: [id])
  matchConfidence Float?    // For AI sorting suggestions (0.0 to 1.0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum Role {
  SUPER_ADMIN
  OPERATOR
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(OPERATOR)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
